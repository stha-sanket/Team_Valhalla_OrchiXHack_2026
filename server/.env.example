PORT=3000
NODE_ENV=development
DATABASE_URL=mongodb://localhost:27017/server
JWT_SECRET=<generate with: openssl rand -hex 64>
REDIS_URL=redis://localhost:6379
CORS_ORIGINS=http://localhost:3000,https://yourapp.com
APP_URL=http://localhost:3000
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your@email.com
SMTP_PASS=your_16_char_app_password # Gmail App Password (16 chars) — NOT your regular Gmail password. Generate at: Google Account > Security > 2-Step Verification > App passwords
SMTP_FROM=noreply@yourapp.com
CROSS_SITE_COOKIES=false
