flowchart TD
  REG["Register / Log in"] --> DASH["Dashboard<br/>points · badges · recent trip"]
  DASH --> EXP["Explore: pick a place"]
  EXP --> NAV["Compass + AR guidance<br/>to next waypoint"]
  NAV --> GEO{"Within geofence<br/>(10 m default)?"}
  GEO -- "no" --> NAV
  GEO -- "yes" --> CONF["User confirms arrival"]
  CONF --> TYPE{"Waypoint type"}
  TYPE -- "node / start / end" --> IMG["Directional image"]
  TYPE -- "milestone" --> VID["Story video +10 pts<br/>permanent milestone"]
  TYPE -- "side quest" --> SQ["Video, then 5-min stay<br/>+25 pts"]
  IMG --> MORE{"Route left?"}
  VID --> MORE
  SQ --> MORE
  MORE -- "yes" --> NAV
  MORE -- "no" --> DONE["Place complete<br/>badge + 20 pts"]
  DONE --> QUIZ["Quiz unlocked<br/>one attempt, up to +35 pts"]
  QUIZ --> REDEEM["Redeem points<br/>for campus perks"]
  DONE --> BOARD["Leaderboard + public profile<br/>(points stay private)"]
